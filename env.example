# =============================================================
# are you happy? — Nosana x ElizaOS Agent Challenge
# =============================================================
# Copy this file to .env and fill in your values.
#   cp .env.example .env

# -------------------------------------------------------------
# LLM — Qwen3.5 via Nosana Inference Endpoint
# -------------------------------------------------------------
# All inference runs through Nosana decentralized GPU network.
# OPENAI_API_KEY is set to "nosana" (placeholder — Nosana endpoint
# doesn't require a real OpenAI key).

OPENAI_API_KEY=nosana
OPENAI_API_URL=https://4ksj3tve5bazqwkuyqdhwdpcar4yutcuxphwhckrdxmu.node.k8s.prd.nos.ci/v1

# Model name as served by the Nosana endpoint
MODEL_NAME=Qwen/Qwen3.5-4B

# -------------------------------------------------------------
# Embedding — via Nosana
# -------------------------------------------------------------
OPENAI_EMBEDDING_URL=https://4yiccatpyxx773jtewo5ccwhw1s2hezq5pehndb6fcfq.node.k8s.prd.nos.ci/v1
OPENAI_EMBEDDING_API_KEY=nosana
OPENAI_EMBEDDING_MODEL=Qwen3-Embedding-0.6B
OPENAI_EMBEDDING_DIMENSIONS=1024

# -------------------------------------------------------------
# Local dev with Ollama (optional fallback)
# -------------------------------------------------------------
# Install Ollama: https://ollama.com/download
# Then: ollama pull qwen2.5:7b && ollama serve
#
# OPENAI_API_KEY=ollama
# OPENAI_API_URL=http://127.0.0.1:11434/v1
# MODEL_NAME=qwen2.5:7b

# -------------------------------------------------------------
# Agent Server — MUST be different from Next.js port (3000)
# -------------------------------------------------------------
SERVER_PORT=3001

# -------------------------------------------------------------
# Next.js proxy → ElizaOS agent
# These are used by app/api/chat/route.ts
# -------------------------------------------------------------
ELIZA_API_URL=http://localhost:3001
ELIZA_AGENT_ID=solace

# -------------------------------------------------------------
# Database (SQLite — auto-created at ./data/db.sqlite)
# -------------------------------------------------------------
# SQLITE_DATA_DIR=./data

# -------------------------------------------------------------
# Optional: Social Integrations
# -------------------------------------------------------------
# TELEGRAM_BOT_TOKEN=
# DISCORD_API_TOKEN=
